# Teamver Design — Production EC2 (AWS ALB 백엔드)
# EC2: /opt/teamver-design (Design 전용 VM — Main BE 는 별도 호스트)
# 배포: bash scripts/validate_deploy_env.sh --production --rds && bash deploy.sh --production --rds
#
# 아키텍처 (Design EC2 ≠ Main BE EC2, Design DB ≠ Main BE GCP DB):
#   - 이 파일 → Design Production EC2 (design.teamver.com, design-api.teamver.com)
#   - Main BE  → 별도 호스트 (api.teamver.com) — ns-teamver-be/.env.production → GCP Cloud SQL
#   - POSTGRES_* → AI Design sidecar 전용 AWS RDS (teamver-design-prod-postgres) 만
#   - TEAMVER_INTERNAL_API_KEY 는 Main BE production env 와 동일 값
#   - Apps JWT (JWKS RS256) — hosted 에서 TEAMVER_JWT_SECRET(HS256) 금지
#
# cp .env.production.example .env.production → secrets 채움 → deploy.sh --production --rds
# POSTGRES_HOST: teamver-design terraform prod apply 후
#   cd ns-teamver-devops/terraform/services/teamver-design
#   terraform output -raw postgres_host

ENV=production

# --- Open Design daemon ---
OD_API_TOKEN=
OPEN_DESIGN_IMAGE=docker.io/vanjayak/open-design:latest
# Build + runtime both bookworm (glibc). Alpine build breaks better-sqlite3 on bookworm runtime.
NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:24-bookworm-slim
RUNTIME_BASE_IMAGE=public.ecr.aws/docker/library/node:24-bookworm-slim
PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
OD_PORT=7456
# Multi-node (ALB 2+): nginx hash upstream uses cluster private IP :7456 — daemon must
# listen on 0.0.0.0, not 127.0.0.1 only, or cross-node /api/* → 502. deploy.sh auto-
# sets 0.0.0.0 when peer render finds backends; explicit value here wins.
OD_DOCKER_PUBLISH_HOST=0.0.0.0
# docs-teamver/34 §13.1 + 07 §3.2 — t3.2xlarge (32 GiB) 상용 SSOT.
# Chromium 6 concurrent + Node heap 4096 + design-api 5 workers 여유.
OD_MEM_LIMIT=8g
# Headless export per-job timeout (ms). Default 30000, min 1000 when unset/invalid.
# OD_EXPORT_TIMEOUT_MS=30000
# 상용 export headroom — §34 Export 성능 개선 §13.1
OD_EXPORT_MAX_CONCURRENT=6
OD_EXPORT_BROWSER_POOL_SIZE=3
OD_EXPORT_QUEUE_MAX=64
OD_EXPORT_TICKET_TTL_SEC=300
# Phase 1 export artifact cache — docs-teamver/34 §20.2·§20.3
# memo (RAM) tier: defaults 32 entries / 32MB each / 256MB total / 120s TTL
# Set OD_EXPORT_CACHE_MEMO_ENABLED=0 to force miss (debugging).
# OD_EXPORT_CACHE_MEMO_MAX_ENTRIES=32
# OD_EXPORT_CACHE_MEMO_MAX_ENTRY_BYTES=33554432
# OD_EXPORT_CACHE_MEMO_MAX_TOTAL_BYTES=268435456
# OD_EXPORT_CACHE_MEMO_TTL_SEC=120
# local (EBS) tier: defaults 5GB total / 7d max age, path under OD_DATA_DIR
# OD_EXPORT_CACHE_DIR=/app/.od/data/.od-export-cache
# OD_EXPORT_CACHE_LOCAL_MAX_TOTAL_BYTES=5368709120
# OD_EXPORT_CACHE_LOCAL_MAX_AGE_SEC=604800
# OD_EXPORT_CACHE_LOCAL_SWEEP_INTERVAL_SEC=3600
# OD_EXPORT_CACHE_VERSION defaults to v6. Override only to force another cache bust.
# OD_EXPORT_CACHE_VERSION=v6
# Export artifact cache (Phase 1a — docs-teamver/34 §20). code default ON;
# 명시적 SSOT 로 EC2 .env 에 남긴다. 프로젝트 파일 mtime 이 cache 키에
# 포함이라 파일 수정 시 자동 miss.
OD_EXPORT_CACHE_ENABLED=1
NODE_OPTIONS=--max-old-space-size=4096
OD_ALLOWED_ORIGINS=https://design.teamver.com
TEAMVER_DESIGN_API_URL=http://teamver-design-api:8000
# async DB / cold RDS headroom (middleware warns on timeout)
TEAMVER_PROJECT_ACCESS_TIMEOUT_MS=5000
# daemon → design-api /access 왕복 감소 SSOT (teamver-project-access.ts).
# 30s grant = 프로젝트 하나 열고 thumbnail/export/publish 동안 재조회 없음.
# Deny 는 짧게 유지 — permission revoke 반영 지연 최소화.
TEAMVER_PROJECT_ACCESS_GRANT_TTL_MS=30000
TEAMVER_PROJECT_ACCESS_DENY_PERMANENT_TTL_MS=5000
TEAMVER_PROJECT_ACCESS_DENY_TRANSIENT_TTL_MS=1500
# Embed slide MVP — daemon plugin catalog defaults to deck-only (video/image excluded).
OD_PLUGIN_CATALOG_DEFAULT_MODE=deck
# Functional skills listing — drop image/video/audio generation skills on boot.
OD_SKILLS_CATALOG_SLIDE_ONLY=1
# Design templates + deck example plugins — exclude Chinese-primary demos from catalog APIs.
OD_DESIGN_TEMPLATES_EXCLUDE_ZH_CN=1

# --- Web build (Docker image bake-time — 변경 시 open-design-daemon 재빌드) ---
VITE_TEAMVER_BOOTSTRAP_ENABLED=1
VITE_TEAMVER_MAIN_LOGIN_URL=https://teamver.com/auth/signin
VITE_TEAMVER_SITE_URL=https://design.teamver.com
# BYOK 스트리밍 중 daemon message PUT throttle (ms). docs-teamver/27_메시지_Persist_PUT_아키텍처.md
VITE_MESSAGE_PERSIST_THROTTLE_MS=5000

# --- OD project storage (09 Phase 0 / Teamver Track A tenant 격리) ---
# REQUIRED: production EC2 는 OD_PROJECT_STORAGE=s3 만 허용 (validate_deploy_env.sh
# 가 .env.production 에서 s3 가 아니면 즉시 실패). local-disk fallback 은
# multi-tenant 격리·내구성을 둘 다 깨므로 금지.
OD_PROJECT_STORAGE=s3
OD_S3_BUCKET=teamver-design-prod-data
OD_S3_REGION=ap-northeast-2
OD_S3_PREFIX=design/
# EC2 IAM instance profile 사용 시 키 불필요 (terraform output project_data_*)
OD_SCRATCH_DIR=/app/.od/scratch
# Hosted EC2 — bind Terraform od-data EBS (production 100 GiB). migrate: scripts/migrate_od_data_ebs.sh --apply --production
OD_DATA_HOST_PATH=/opt/teamver-design/od-data
OD_PROJECT_LAZY_SYNC_TTL_MS=60000
# registry delete — Teamver 표준: S3 tenant SSOT 유지 (=0). 법적 erasure만 =1 (daemon default ON if unset)
OD_S3_PURGE_ON_DELETE=0
OD_SCRATCH_EVICT_AFTER_RUN=1
OD_SCRATCH_EVICT_IDLE=1
# OD_SCRATCH_EVICT_IDLE_AFTER_MS=120000
OD_S3_SYNC_UP_METRICS=1
# embed BYOK proxy 스트림 sync 훅 (mode=api). docs-teamver/29
# OD_BYOK_PROXY_MATERIALIZATION=1
# BYOK proxy sync-down 실패 시 502 (default on). 0=데이터 손실 위험, 끄지 말 것
# OD_BYOK_PROXY_FAIL_ON_BEGIN=1
# workspace 당 BYOK proxy 동시 스트림 상한 (미설정=default 8, 0=cap 비활성). docs-teamver/38 §5
# OD_BYOK_PROXY_MAX_PER_WORKSPACE=8
# BYOK billing staging TTL — terminal PUT 누락 시 reap (default 10분)
# OD_BYOK_BILLING_STAGE_TTL_MS=600000
# S3 sync 재시도 — run-end / lazy / strict / background (defaults: 2·500ms / 3·250ms / 3·300ms / 2·500ms)
# OD_S3_RUN_END_SYNC_UP_RETRIES=2
# OD_S3_RUN_END_SYNC_UP_RETRY_MS=500
# OD_S3_MATERIALIZE_RETRIES=3
# OD_S3_MATERIALIZE_RETRY_MS=250
# OD_S3_STRICT_PERSIST_RETRIES=3
# OD_S3_STRICT_PERSIST_RETRY_MS=300
# OD_S3_BACKGROUND_PERSIST_RETRIES=2
# OD_S3_BACKGROUND_PERSIST_RETRY_MS=500
# BYOK 매 turn 후 scratch evict (default off — 멀티턴 캐시 보호)
# OD_SCRATCH_EVICT_AFTER_BYOK_TURN=0
# scratch 용량 관측 — docs-teamver/21_OD_SCRATCH_DISK_METRICS_가이드.md
OD_SCRATCH_DISK_METRICS=1
OD_SCRATCH_DISK_THRESHOLD_MB=2048
OD_SCRATCH_DISK_METRIC_INTERVAL_MS=300000
AWS_REGION=ap-northeast-2

# --- Multi-node identity (docs-teamver/39_2 · 39_5) ---
# ALB stickiness 검증·failover triage 용. Phase 4 (2 EC2 + sticky) 부터 필수
# 관측 필드. 미설정 시 deploy.sh 가 EC2 IMDS 로 instance-id 를 조회해 자동
# 주입 — 별도 지정 필요 없음. 명시 override 필요할 때만 값을 채운다.
# OD_NODE_ID=

# --- Litestream (hosted 필수 — deploy.sh가 항상 sidecar 시작) ---
# app.sqlite 메타·세션을 프로젝트 bucket의 litestream/ prefix에 복제한다.
LITESTREAM_BUCKET=teamver-design-prod-data
LITESTREAM_REGION=ap-northeast-2
LITESTREAM_SYNC_INTERVAL=3s
# Litestream 장애 시 수동 fallback: bash scripts/backup_sqlite_to_s3.sh --production --stop-daemon
# SQLITE_BACKUP_PREFIX=sqlite-backups

# --- teamver-design-api (deploy/teamver/be) ---
BE_PORT=16000
# uvicorn multi-worker — production t3.2xlarge (8 vCPU) 상용 SSOT.
# workers=5 (async I/O-bound). OD daemon(Chromium export) 과 vCPU 공유 — 6 이상은
# export burst 때 latency 경쟁. EC2 는 prod.terraform.tfvars ec2_instance_type.
# RDS: 5 × (pool_size 8 + max_overflow 8) = 80 커넥션 (~18% of t4g.medium ~450).
UVICORN_WORKERS=5
UVICORN_LIMIT_CONCURRENCY=150
UVICORN_TIMEOUT_KEEP_ALIVE=30
# SQLAlchemy async pool — 워커 × (size + max_overflow) ≤ RDS max_connections 여유치.
# 값 조정 시 pg_stat_activity + /api/healthz/deps pool 필드 확인.
DB_POOL_SIZE=8
DB_POOL_MAX_OVERFLOW=8
DB_POOL_RECYCLE_SEC=1800
DB_POOL_TIMEOUT_SEC=30
# Slow-request 관측 — CloudWatch metric filter 는 `slow_request` 문자열 +
# `duration_ms=NNN` 를 매칭한다. 1000ms 는 상용 목표 p95 상한 (참조:
# docs-teamver/34 §운영 튜닝). 배포 초기에는 500ms 로 낮춰 병목 route 를
# 노출한 뒤 안정화되면 1000~1500ms 로 완만화 권장.
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_REQUEST_HEADER_ENABLED=1
# Main BE production — 별도 EC2/ALB (Design compose 내부가 아님)
TEAMVER_API_BASE_URL=https://api.teamver.com
# Apps JWT (RS256 JWKS) — Mail pilot pattern (15_8). production: TEAMVER_JWT_SECRET 금지.
TEAMVER_JWKS_URL=https://api.teamver.com/.well-known/jwks.json
TEAMVER_JWT_ISSUER=https://api.teamver.com
TEAMVER_JWT_AUDIENCE=teamver-design
TEAMVER_JWKS_CACHE_TTL_SEC=900
TEAMVER_BFF_SESSION_ENABLED=true
# openssl rand -hex 32
DESIGN_BFF_SESSION_SECRET=
# App-specific cookie name. Do not use generic "session" because Main Teamver
# may also send a .teamver.com session cookie.
DESIGN_BFF_SESSION_COOKIE_NAME=teamver_design_bff_session
DESIGN_PUBLIC_ORIGIN=https://design.teamver.com
TEAMVER_MAIN_LOGIN_URL=https://teamver.com/auth/signin
TEAMVER_AUTH_COOKIE_NAME=teamver_access_token
TEAMVER_AUTH_COOKIE_DOMAIN=.teamver.com
TEAMVER_APP_KEY=design
# Main BE TEAMVER_INTERNAL_API_KEY 와 동일 (daemon → design-api usage M2M)
TEAMVER_INTERNAL_API_KEY=
TEAMVER_BOOTSTRAP_ENABLED=true
TEAMVER_BOOTSTRAP_CACHE_TTL_SECONDS=300
TEAMVER_BOOTSTRAP_CACHE_STALE_GRACE_SECONDS=300
TEAMVER_HTTP_TIMEOUT_SECONDS=5
TEAMVER_DRIVE_PROXY_LONG_TIMEOUT_SECONDS=30
# nginx auth_request 검증 후 전달되는 X-Teamver-* 헤더만 신뢰
TRUST_TEAMVER_PROXY_HEADERS=true

# --- Usage ledger + Registry billing (11 §3 / ai_model_token_usages) ---
# Run 종료 시 OD daemon → design-api POST /api/internal/usage/events → RDS.
# 필수: TEAMVER_DESIGN_API_URL + TEAMVER_INTERNAL_API_KEY.
#
# Registry Phase 2 (Main BE reserve/commit) 는 당분간 미구현 — staging·production 공통:
#   · 기본(권장): TEAMVER_BILLING_DISABLED=1 → usage ledger만 RDS 기록, 크레딧 차감 없음
#   · Registry E2E 준비 후: 아래 3종 설정 + TEAMVER_BILLING_DISABLED 제거
TEAMVER_BILLING_DISABLED=1
#
# TEAMVER_REGISTRY_APP_ID=ai-design
# TEAMVER_REGISTRY_KEY_ID=
# TEAMVER_REGISTRY_ACCESS_KEY=
#
# daemon billing bridge (선택)
# TEAMVER_BILLING_RESERVE_AMOUNT=0
# Token → credit(T) meter for ledger audit (see docs-teamver/11 §4.5)
# DESIGN_MODEL_PRICES_JSON={"claude-sonnet-4-5":{"input_per_1k_t":3,"output_per_1k_t":15,"cache_read_per_1k_t":1,"cache_creation_per_1k_t":4}}
# TEAMVER_BILLING_TIMEOUT_MS=5000

# design-api → OD daemon (Publish + export; compose default http://open-design-daemon:7456)
OD_DAEMON_BASE_URL=http://open-design-daemon:7456
OD_DAEMON_TIMEOUT_SECONDS=120
# Drive publish stream PUT safety net. Normal path streams daemon export ticket
# directly to the presigned URL; if the endpoint rejects streaming, files up to
# this size retry once with the legacy bytes PUT path (default 64MB).
# TEAMVER_DRIVE_PUBLISH_STREAM_FALLBACK_MAX_BYTES=67108864
# Optional — default Drive folder for publish (workspace folder id)
# TEAMVER_DRIVE_PUBLISH_FOLDER_ID=

# Optional — Drive publish 폴더 (Phase 4 G7 권장)

CORS_ORIGINS=https://design.teamver.com
CORS_TEAMVER_SUBDOMAIN_REGEX=true

# teamver-design Terraform prod — AI Design sidecar 전용 AWS RDS (teamver-design-prod-postgres)
# ≠ Main BE production DB (GCP Cloud SQL). docs: .../teamver-design/docs/DATABASE.md
# database teamver_design_production 은 Terraform db_name 으로 생성됨 (CREATE DATABASE 수동 불필요)
# POSTGRES_HOST: prod apply 후 `terraform output -raw postgres_host` 로 채움
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=teamver_design_production
POSTGRES_USER=teamver_design_admin
POSTGRES_PASSWD=
# RDS TLS: require = 암호화 ON, cert 검증 OFF (libpq semantics).
# design-api asyncpg 는 connection.py 가 require/prefer 를 verify-off SSL context 로 매핑.
POSTGRES_SSLMODE=require

# --- OD DaemonDb (Track B5 — multi-node chat SSOT) ---
# design-api 와 동일 RDS 인스턴스, 별도 database.
# 이름 SSOT: terraform/services/teamver-design → daemon_db_name / rds_create_daemon_database_sql
#   terraform output -raw rds_create_daemon_database_sql   # 1회 CREATE DATABASE
#   terraform output -raw daemon_db_name                   # → OD_PG_DATABASE
# Phase 4 (ec2_instance_count=2): staging 과 같이 OD_DAEMON_DB=postgres 권장
# (노드별 app.sqlite 분열 방지). 테이블 DDL: daemon boot migrate.
# OD_DAEMON_DB=postgres
# OD_PG_HOST=teamver-design-prod-postgres.c70wg0euku9u.ap-northeast-2.rds.amazonaws.com
# OD_PG_PORT=5432
# OD_PG_DATABASE=teamver_design_daemon_production
# OD_PG_USER=teamver_design_admin
# OD_PG_PASSWORD=   # POSTGRES_PASSWD 와 동일 (Design RDS master)
# OD_PG_SSL_MODE=require

# --- OD daemon LLM keys (server-side only — git 커밋 금지) ---
# REQUIRED FOR PROD: 아래 daemon key (ANTHROPIC/OPENAI) 또는 design-api 의
# TEAMVER_OD_API_KEY (managed API) 중 최소 하나는 채워야 함. validate_deploy_env.sh
# --production 에서 둘 다 비어 있으면 즉시 fail (공개 사용자 chat 게이트).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- design-api embed runtime (API mode managed — git 커밋 금지) ---
# REQUIRED FOR PROD (or daemon LLM key above).
# TEAMVER_OD_API_KEY=
# TEAMVER_OD_API_PROTOCOL=anthropic
# TEAMVER_OD_API_BASE_URL=https://api.anthropic.com
# TEAMVER_OD_API_MODEL=claude-sonnet-4-5

# --- AWS credentials (PROHIBITED in prod) ---
# Production 은 EC2 IAM instance profile 만 허용. 정적 키가 있으면 validate
# 가 fail. 긴급 우회: ALLOW_STATIC_AWS_KEYS=1 (회수 후 즉시 키도 회수).
# OD_S3_ACCESS_KEY_ID=
# OD_S3_SECRET_ACCESS_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Ops alarms (print commands only) ---
# LOG_GROUP=/teamver/design/prod/open-design-daemon
# SNS_TOPIC_ARN=
