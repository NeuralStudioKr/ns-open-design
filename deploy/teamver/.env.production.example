# Teamver Design — Production EC2 (AWS ALB 백엔드)
# EC2: /opt/teamver-design (Design 전용 VM — Main BE 는 별도 호스트)
# 배포: bash scripts/validate_deploy_env.sh --production --rds && bash deploy.sh --production --rds
#
# 아키텍처 (Design EC2 ≠ Main BE EC2, Design DB ≠ Main BE GCP DB):
#   - 이 파일 → Design Production EC2 (design.teamver.com, design-api.teamver.com)
#   - Main BE  → 별도 호스트 (api.teamver.com) — ns-teamver-be/.env.production → GCP Cloud SQL
#   - POSTGRES_* → AI Design sidecar 전용 AWS RDS (teamver-design-prod-postgres) 만
#   - 아래 TEAMVER_JWT_SECRET / TEAMVER_INTERNAL_API_KEY 는 Main BE production env 와
#     동일 값이어야 한다 (JWT_SECRET_KEY, TEAMVER_INTERNAL_API_KEY).
#
# cp .env.production.example .env.production → secrets 채움 → deploy.sh --production --rds
# POSTGRES_HOST: teamver-design terraform prod apply 후
#   cd ns-teamver-devops/terraform/services/teamver-design
#   terraform output -raw postgres_host

ENV=production

# --- Open Design daemon ---
OD_API_TOKEN=
OPEN_DESIGN_IMAGE=docker.io/vanjayak/open-design:latest
NODE_BASE_IMAGE=public.ecr.aws/docker/library/node:24-alpine
PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
OD_PORT=7456
OD_MEM_LIMIT=2g
NODE_OPTIONS=--max-old-space-size=1536
OD_ALLOWED_ORIGINS=https://design.teamver.com
TEAMVER_DESIGN_API_URL=http://teamver-design-api:8000
# async DB / cold RDS headroom (middleware warns on timeout)
TEAMVER_PROJECT_ACCESS_TIMEOUT_MS=5000

# --- OD project storage (09 Phase 0 / Teamver Track A tenant 격리) ---
# REQUIRED: production EC2 는 OD_PROJECT_STORAGE=s3 만 허용 (validate_deploy_env.sh
# 가 .env.production 에서 s3 가 아니면 즉시 실패). local-disk fallback 은
# multi-tenant 격리·내구성을 둘 다 깨므로 금지.
OD_PROJECT_STORAGE=s3
OD_S3_BUCKET=teamver-design-prod-data
OD_S3_REGION=ap-northeast-2
OD_S3_PREFIX=design/
# EC2 IAM instance profile 사용 시 키 불필요 (terraform output project_data_*)
OD_SCRATCH_DIR=/app/.od/scratch
OD_PROJECT_LAZY_SYNC_TTL_MS=60000
# registry delete → tenant S3 purge (default on; disable: OD_S3_PURGE_ON_DELETE=0)
# OD_S3_PURGE_ON_DELETE=0
OD_SCRATCH_EVICT_AFTER_RUN=1
OD_SCRATCH_EVICT_IDLE=1
# OD_SCRATCH_EVICT_IDLE_AFTER_MS=120000
OD_S3_SYNC_UP_METRICS=1
# scratch 용량 관측 — docs-teamver/21_OD_SCRATCH_DISK_METRICS_가이드.md
OD_SCRATCH_DISK_METRICS=1
OD_SCRATCH_DISK_THRESHOLD_MB=2048
OD_SCRATCH_DISK_METRIC_INTERVAL_MS=300000
AWS_REGION=ap-northeast-2

# --- Litestream (hosted 필수 — deploy.sh가 항상 sidecar 시작) ---
# app.sqlite 메타·세션을 프로젝트 bucket의 litestream/ prefix에 복제한다.
LITESTREAM_BUCKET=teamver-design-prod-data
LITESTREAM_REGION=ap-northeast-2
LITESTREAM_SYNC_INTERVAL=3s
# Litestream 장애 시 수동 fallback: bash scripts/backup_sqlite_to_s3.sh --production --stop-daemon
# SQLITE_BACKUP_PREFIX=sqlite-backups

# --- teamver-design-api (deploy/teamver/be) ---
BE_PORT=16000
# Main BE production — 별도 EC2/ALB (Design compose 내부가 아님)
TEAMVER_API_BASE_URL=https://api.teamver.com
# Main BE JWT_SECRET_KEY 와 동일
TEAMVER_JWT_SECRET=
TEAMVER_JWT_ALGORITHM=HS256
TEAMVER_AUTH_COOKIE_NAME=teamver_access_token
TEAMVER_APP_KEY=design
# Main BE TEAMVER_INTERNAL_API_KEY 와 동일 (daemon → design-api usage M2M)
TEAMVER_INTERNAL_API_KEY=
TEAMVER_BOOTSTRAP_ENABLED=true
TEAMVER_BOOTSTRAP_CACHE_TTL_SECONDS=120
TEAMVER_HTTP_TIMEOUT_SECONDS=5
TEAMVER_DRIVE_PROXY_LONG_TIMEOUT_SECONDS=30
# nginx auth_request 검증 후 전달되는 X-Teamver-* 헤더만 신뢰
TRUST_TEAMVER_PROXY_HEADERS=true

# --- Usage ledger + Registry billing (11 §3 / ai_model_token_usages) ---
# Run 종료 시 OD daemon → design-api POST /api/internal/usage/events → RDS.
# 필수: TEAMVER_DESIGN_API_URL + TEAMVER_INTERNAL_API_KEY.
#
# Registry Phase 2 (Main BE reserve/commit) 는 당분간 미구현 — staging·production 공통:
#   · 기본(권장): TEAMVER_BILLING_DISABLED=1 → usage ledger만 RDS 기록, 크레딧 차감 없음
#   · Registry E2E 준비 후: 아래 3종 설정 + TEAMVER_BILLING_DISABLED 제거
TEAMVER_BILLING_DISABLED=1
#
# TEAMVER_REGISTRY_APP_ID=ai-design
# TEAMVER_REGISTRY_KEY_ID=
# TEAMVER_REGISTRY_ACCESS_KEY=
#
# daemon billing bridge (선택)
# TEAMVER_BILLING_RESERVE_AMOUNT=0
# TEAMVER_BILLING_TIMEOUT_MS=5000

# design-api → OD daemon (Publish + export; compose default http://open-design-daemon:7456)
OD_DAEMON_BASE_URL=http://open-design-daemon:7456
OD_DAEMON_TIMEOUT_SECONDS=120
# Optional — default Drive folder for publish (workspace folder id)
# TEAMVER_DRIVE_PUBLISH_FOLDER_ID=

# Optional — Drive publish 폴더 (Phase 4 G7 권장)

CORS_ORIGINS=https://design.teamver.com
CORS_TEAMVER_SUBDOMAIN_REGEX=true

# teamver-design Terraform prod — AI Design sidecar 전용 AWS RDS (teamver-design-prod-postgres)
# ≠ Main BE production DB (GCP Cloud SQL). docs: .../teamver-design/docs/DATABASE.md
# database teamver_design_production 은 Terraform db_name 으로 생성됨 (CREATE DATABASE 수동 불필요)
# POSTGRES_HOST: prod apply 후 `terraform output -raw postgres_host` 로 채움
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=teamver_design_production
POSTGRES_USER=teamver_design_admin
POSTGRES_PASSWD=
# RDS TLS: require = 암호화 ON, cert 검증 OFF (libpq semantics).
# design-api asyncpg 는 connection.py 가 require/prefer 를 verify-off SSL context 로 매핑.
POSTGRES_SSLMODE=require

# --- OD daemon LLM keys (server-side only — git 커밋 금지) ---
# REQUIRED FOR PROD: 아래 daemon key (ANTHROPIC/OPENAI) 또는 design-api 의
# TEAMVER_OD_API_KEY (managed API) 중 최소 하나는 채워야 함. validate_deploy_env.sh
# --production 에서 둘 다 비어 있으면 즉시 fail (공개 사용자 chat 게이트).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- design-api embed runtime (API mode managed — git 커밋 금지) ---
# REQUIRED FOR PROD (or daemon LLM key above).
# TEAMVER_OD_API_KEY=
# TEAMVER_OD_API_PROTOCOL=anthropic
# TEAMVER_OD_API_BASE_URL=https://api.anthropic.com
# TEAMVER_OD_API_MODEL=claude-sonnet-4-5

# --- AWS credentials (PROHIBITED in prod) ---
# Production 은 EC2 IAM instance profile 만 허용. 정적 키가 있으면 validate
# 가 fail. 긴급 우회: ALLOW_STATIC_AWS_KEYS=1 (회수 후 즉시 키도 회수).
# OD_S3_ACCESS_KEY_ID=
# OD_S3_SECRET_ACCESS_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Ops alarms (print commands only) ---
# LOG_GROUP=/teamver/design/prod/open-design-daemon
# SNS_TOPIC_ARN=
