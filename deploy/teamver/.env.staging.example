# Teamver Design — Staging EC2 (AWS)
# EC2: /opt/teamver-design (Design Staging VM — Main BE 는 별도 EC2)
# 배포: bash scripts/validate_deploy_env.sh --staging --rds && bash deploy.sh --staging --rds
# (또는 bash scripts/run_docker.sh --staging --rds — deploy.sh 로 위임)
#
# 아키텍처 (Design EC2 ≠ Main BE EC2):
#   - 이 파일 → Design Staging EC2 (stg-design.teamver.com, stg-design-api.teamver.com)
#   - Main BE  → 별도 Staging EC2 (stg-api.teamver.com) — ns-teamver-be/.env.staging
#   - TEAMVER_JWT_SECRET / TEAMVER_INTERNAL_API_KEY 는 Main BE staging env 와 동일 값
#     (JWT_SECRET_KEY, TEAMVER_INTERNAL_API_KEY).
#
# cp .env.staging.example .env.staging → secrets 채움
# S3/RDS merge: bash scripts/run_staging_phase0_activate.sh --from-terraform

ENV=staging

# --- Open Design daemon ---
OD_API_TOKEN=
OPEN_DESIGN_IMAGE=docker.io/vanjayak/open-design:latest
OD_PORT=7456
OD_MEM_LIMIT=1536m
NODE_OPTIONS=--max-old-space-size=1024
OD_ALLOWED_ORIGINS=https://stg-design.teamver.com
TEAMVER_DESIGN_API_URL=http://teamver-design-api:8000
TEAMVER_PROJECT_ACCESS_TIMEOUT_MS=5000

# --- OD project storage (09 Phase 0 / Teamver Track A tenant 격리) ---
# REQUIRED: staging EC2 는 OD_PROJECT_STORAGE=s3 만 허용 (validate_deploy_env.sh
# 가 .env.staging 에서 s3 가 아니면 즉시 실패). local-disk fallback 은
# multi-tenant 격리·내구성을 둘 다 깨므로 금지.
#
# 활성화(EC2): bash scripts/apply_staging_s3_env.sh [--from-terraform]
# 로컬 laptop S3 경로만 검증: MinIO — bash scripts/run_minio_s3_dev.sh (09 §10.1)
#   → laptop dev 시에는 .env (no -staging) 에서만 OD_PROJECT_STORAGE=local 허용.
OD_PROJECT_STORAGE=s3
OD_S3_BUCKET=teamver-design-staging-data
OD_S3_REGION=ap-northeast-2
OD_S3_PREFIX=design/
# IAM instance profile 사용 시 access/secret 키 불필요 (terraform 권장)
# OD_S3_ACCESS_KEY_ID=
# OD_S3_SECRET_ACCESS_KEY=
OD_SCRATCH_DIR=/app/.od/scratch
OD_PROJECT_LAZY_SYNC_TTL_MS=60000
# registry delete → tenant S3 purge (default on; disable: OD_S3_PURGE_ON_DELETE=0)
# OD_S3_PURGE_ON_DELETE=0
OD_SCRATCH_EVICT_AFTER_RUN=1
OD_S3_SYNC_UP_METRICS=1
OD_SCRATCH_DISK_METRICS=1
OD_SCRATCH_DISK_THRESHOLD_MB=2048
OD_SCRATCH_DISK_METRIC_INTERVAL_MS=300000
AWS_REGION=ap-northeast-2

# --- Litestream (optional — docker compose --profile litestream) ---
# LITESTREAM_BUCKET=teamver-design-staging-data
# LITESTREAM_REGION=ap-northeast-2
# Litestream 장애 시 수동 fallback: bash scripts/backup_sqlite_to_s3.sh --staging --stop-daemon
# SQLITE_BACKUP_PREFIX=sqlite-backups

# --- teamver-design-api (deploy/teamver/be) ---
BE_PORT=16000
# Main BE staging — 별도 EC2 (Design compose 내부가 아님)
TEAMVER_API_BASE_URL=https://stg-api.teamver.com
# Main BE JWT_SECRET_KEY 와 동일
TEAMVER_JWT_SECRET=
TEAMVER_JWT_ALGORITHM=HS256
TEAMVER_AUTH_COOKIE_NAME=teamver_access_token
TEAMVER_APP_KEY=design
# Main BE TEAMVER_INTERNAL_API_KEY 와 동일
TEAMVER_INTERNAL_API_KEY=
TEAMVER_BOOTSTRAP_ENABLED=true
TEAMVER_BOOTSTRAP_CACHE_TTL_SECONDS=120
TEAMVER_HTTP_TIMEOUT_SECONDS=5
# nginx auth_request 검증 후 전달되는 X-Teamver-* 헤더만 신뢰
TRUST_TEAMVER_PROXY_HEADERS=true

# design-api → OD daemon (Publish + export; compose default http://open-design-daemon:7456)
OD_DAEMON_BASE_URL=http://open-design-daemon:7456
OD_API_TOKEN=
OD_DAEMON_TIMEOUT_SECONDS=120
# Optional — default Drive folder for publish (workspace folder id, e.g. FLD-…)
# TEAMVER_DRIVE_PUBLISH_FOLDER_ID=

CORS_ORIGINS=https://stg-design.teamver.com
CORS_TEAMVER_SUBDOMAIN_REGEX=true

# teamver-design Terraform — teamver-staging-postgres (Main BE RDS 와 동일 인스턴스, DB 만 분리)
POSTGRES_HOST=teamver-staging-postgres.c70wg0euku9u.ap-northeast-2.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=teamver_design_staging
POSTGRES_USER=teamver_be_admin
POSTGRES_PASSWD=
# RDS TLS: require = 암호화 ON, cert 검증 OFF (libpq semantics).
# design-api asyncpg 는 connection.py 가 require/prefer 를 verify-off SSL context 로 매핑.
POSTGRES_SSLMODE=require

# --- OD daemon LLM keys (optional, server-side only — git 커밋 금지) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- design-api embed runtime (API mode BYOK — git 커밋 금지) ---
# TEAMVER_OD_API_KEY=
#
# URL 읽기(web_fetch)는 daemon BYOK tool loop 필요 — anthropic 단독 base stream 은
# text-only라 web_fetch 가 동작하지 않음 (FAQ doc 15 Q6).
# tool loop 예 (senseaudio / aihubmix — loop 184):
# TEAMVER_OD_API_PROTOCOL=aihubmix
# TEAMVER_OD_API_BASE_URL=https://aihubmix.com/v1
# TEAMVER_OD_API_MODEL=<tool-call 지원 모델>
#
# text-only (web_fetch 없음):
# TEAMVER_OD_API_PROTOCOL=anthropic
# TEAMVER_OD_API_BASE_URL=https://api.anthropic.com
# TEAMVER_OD_API_MODEL=claude-sonnet-4-5

# --- Ops alarms (print commands only) ---
# LOG_GROUP=/teamver/design/staging/open-design-daemon
# SNS_TOPIC_ARN=
