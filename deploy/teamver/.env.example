# Teamver deploy sidecar — 환경별 env
#
# 인프라 SSOT: docs-teamver/07_VM_배포_인프라.md
# Storage 모드 (local / MinIO / staging S3): docs-teamver/09 §10.1
# Usage ledger + billing env: docs-teamver/11_Usage·Drive_Publish_보강.md §3
# Apps JWT BFF (15_8): docs-teamver/10_세션·OD패치_보강.md §0
#
# Staging VM:    cp .env.staging.example .env.staging
# Production VM: cp .env.production.example .env.production
#
# hosted staging/production 필수 (validate_deploy_env.sh):
#   TEAMVER_JWKS_URL, TEAMVER_JWT_ISSUER, TEAMVER_JWT_AUDIENCE=teamver-design
#   DESIGN_BFF_SESSION_SECRET, TEAMVER_INTERNAL_API_KEY (Main BE 와 동일)
#   TEAMVER_JWT_SECRET(HS256) — 설정 금지
#
# Registry Phase 2 미구현 기간 — 둘 다 기본 TEAMVER_BILLING_DISABLED=1
#   (usage ledger RDS 기록 O, 크레딧 reserve/commit X)
# Registry 연동 후: TEAMVER_REGISTRY_* 3종 + BILLING_DISABLED 제거
#
# bash scripts/run_docker.sh --staging | --production
