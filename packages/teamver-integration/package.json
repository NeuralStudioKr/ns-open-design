{
  "name": "@open-design/teamver-integration",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "Headless open-design daemon client for Teamver design-app orchestration (HTTP/SSE only; no Teamver SDK).",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "node ./esbuild.config.mjs && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-design/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "esbuild": "0.28.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "~24"
  }
}
